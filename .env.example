# ── LLM ─────────────────────────────────────────────────────────────────────
# DeepInfra key for Kimi K2 Thinking (primary)
KIMI_API_KEY=

# Moonshot direct key for fallback
KIMI_FALLBACK_KEY=

# ── Monitoring ───────────────────────────────────────────────────────────────
# Healthchecks.io check UUID (from your check's ping URL)
HEALTHCHECK_UUID=

# ── Cloudflare R2 (backup + verifier) ───────────────────────────────────────
# R2 account ID (used in endpoint URL: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
R2_ACCOUNT_ID=

# Backup bucket name
R2_BUCKET=monet-state-backup

# R2 credentials for the main backup (restic uses these)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Scoped verifier credentials — separate key, only write access to verifier/ prefix
# mon€t HOLDS these only for pushing tip hashes (write-only to verifier/)
R2_VERIFIER_ACCESS_KEY_ID=
R2_VERIFIER_SECRET_ACCESS_KEY=

# ── Telegram (iMessage bridge) ───────────────────────────────────────────────
# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat IDs — obtain by messaging @userinfobot in each chat after starting the bot
TELEGRAM_CHAT_ID_DAMIAN=
TELEGRAM_CHAT_ID_JENNY=
TELEGRAM_CHAT_ID_GROUP=

# ── Moltbook ─────────────────────────────────────────────────────────────────
MOLTBOOK_API_KEY=

# ── Runtime ──────────────────────────────────────────────────────────────────
DATA_DIR=/data

# ── Notes ────────────────────────────────────────────────────────────────────
# COINBASE_AGENTKIT_KEY is NOT set here — it is added only at Tier 2 unlock,
# routed through Fly's Tokenizer proxy per SECURITY.md.
#
# There is NO journal decryption key. The private key was destroyed in the
# setup ceremony. This is by design; see SOUL.md and DEPLOY.md.
